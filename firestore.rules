rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // User profile + streak data
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null && request.auth.uid == uid;

      // Anti-tamper: client cannot increase currentStreak by more than 1
      allow update: if request.auth != null && request.auth.uid == uid
        && (
          !('currentStreak' in request.resource.data)
          || !('currentStreak' in resource.data)
          || request.resource.data.currentStreak <= resource.data.currentStreak + 1
        );

      // Account deletion only via server action (admin SDK bypasses rules)
      allow delete: if false;
    }

    // All user-scoped subcollections (folders, decks, cards, reviews)
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
